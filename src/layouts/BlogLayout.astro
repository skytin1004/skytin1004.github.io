---
import ThemeToggle from '../components/ThemeToggle'
import { getAuthor } from '../lib/authors'
import { site } from '../lib/site'

type TocItem = {
  id: string
  title: string
  children?: TocItem[]
}

type NavSection = {
  title: string
  links: { title: string; href: string }[]
}

type PageVariant = 'home' | 'listing' | 'article' | 'about'

const props = Astro.props as {
  title: string
  intro?: string
  currentPath: string
  toc?: TocItem[]
  navigation?: NavSection[]
  subtitle?: string
  author?: string
  date?: Date | string
  updatedAt?: Date | string
  readingTimeMinutes?: number
  category?: string
  tags?: string[]
  takeaways?: string[]
  variant?: PageVariant
}

const {
  title,
  intro,
  currentPath,
  toc = [],
  navigation: sidebarNavigation = [],
  subtitle = 'Tech Blog',
  author,
  date,
  updatedAt,
  readingTimeMinutes,
  category,
  tags = [],
  takeaways = [],
  variant = 'article',
} = props

const authorProfile = getAuthor(author)

function formatDate(value: Date | string | undefined): string | null {
  if (!value) return null
  if (value instanceof Date) {
    return (
      value.toLocaleDateString?.('en', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }) ?? value.toISOString().slice(0, 10)
    )
  }
  return value
}

const formattedPublishedDate = formatDate(date)
const formattedUpdatedDate = formatDate(updatedAt)

let displayDateLabel: string | null = null
let displayDateValue: string | null = null

if (formattedUpdatedDate) {
  displayDateLabel = 'Updated '
  displayDateValue = formattedUpdatedDate
} else if (formattedPublishedDate) {
  displayDateValue = formattedPublishedDate
}

let displayReadingTime: string | null = null
if (typeof readingTimeMinutes === 'number') {
  displayReadingTime = `${readingTimeMinutes} min read`
}

let displayMeta: string | null = null
if (displayDateValue && displayReadingTime) {
  displayMeta = `${displayDateLabel ?? ''}${displayDateValue} / ${displayReadingTime}`
} else if (displayDateValue) {
  displayMeta = `${displayDateLabel ?? ''}${displayDateValue}`
} else if (displayReadingTime) {
  displayMeta = displayReadingTime
}

function isTopLinkActive(href: string) {
  if (href === '/blog') {
    return currentPath === '/' || currentPath.startsWith('/blog')
  }
  return currentPath === href
}

const isHome = variant === 'home'
const isListing = variant === 'listing'
const isArticle = variant === 'article'
const isAbout = variant === 'about'
const showArchive = sidebarNavigation.length > 0 && isListing
const showToc = toc.length > 0 && (isArticle || isAbout)
const proseContent = isArticle || isAbout
---

<div class="min-h-screen overflow-x-hidden bg-bg text-text dark:bg-slate-950 dark:text-white">
  <div class="editorial-grid pointer-events-none fixed inset-0 z-0 opacity-80 dark:opacity-20" />

  <header class="sticky top-0 z-50 border-b border-border bg-bg/90 backdrop-blur-xl dark:border-slate-800 dark:bg-slate-950/88">
    <div class="mx-auto flex h-16 max-w-8xl items-center justify-between px-3 sm:px-6 lg:px-8">
      <a href="/" class="group inline-flex min-w-0 items-center gap-3 text-text dark:text-white">
        <span class="grid h-8 w-8 place-items-center border border-[var(--color-text)] bg-[var(--color-text)] font-display text-[0.68rem] font-semibold tracking-[0.14em] text-[var(--color-bg)] transition-colors group-hover:border-brand group-hover:bg-brand dark:border-white dark:bg-white dark:text-slate-950">
          MS
        </span>
        <span class="leading-none">
          <span class="block truncate font-display text-sm font-medium tracking-tight">{site.name}</span>
          <span class="mt-1 hidden text-[0.68rem] uppercase tracking-[0.16em] text-text-secondary sm:block dark:text-slate-400">
            AI systems / developer tools
          </span>
        </span>
      </a>

      <div class="flex min-w-0 items-center gap-1 sm:gap-5">
        <nav aria-label="Primary navigation" class="flex items-center gap-1 text-sm sm:gap-2">
          {site.navigation.map((item) => {
            const active = isTopLinkActive(item.href)
            return (
              <a
                href={item.href}
                class={
                  'px-2 py-2 font-medium transition-colors sm:px-3 ' +
                  (active
                    ? 'text-text dark:text-white'
                    : 'text-text-secondary hover:text-text dark:text-slate-400 dark:hover:text-white')
                }
              >
                {item.title}
              </a>
            )
          })}
        </nav>
        <div class="hidden sm:block">
          <ThemeToggle client:load />
        </div>
      </div>
    </div>
  </header>

  <section class="relative z-10 border-b border-border dark:border-slate-800">
    <div
      class:list={[
        'mx-auto max-w-8xl px-4 sm:px-6 lg:px-8',
        isHome
          ? 'py-16 sm:py-20 lg:py-24'
          : isArticle
            ? 'py-10 sm:py-12 lg:py-14'
            : 'py-12 sm:py-16 lg:py-20',
      ]}
    >
      {isHome ? (
        <div class="grid min-w-0 gap-12 lg:grid-cols-[minmax(0,1.1fr)_24rem] lg:items-end">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-semibold uppercase tracking-[0.22em] text-brand">
              <span>Technical publication</span>
              <span class="h-px w-8 bg-border" />
              <span>Senior engineer portfolio</span>
            </div>
            <h1 class="mt-6 max-w-[12ch] break-words font-display text-4xl font-medium leading-[1.02] tracking-tight text-text sm:max-w-4xl sm:text-6xl sm:leading-[0.98] lg:text-7xl dark:text-white">
              Practical AI engineering, written from the build floor.
            </h1>
            <p class="mt-7 max-w-2xl break-words text-lg leading-8 text-text-secondary sm:text-xl sm:leading-9 dark:text-slate-300">
              {site.description}
            </p>
            <div class="mt-10 grid max-w-3xl grid-cols-1 border-y border-border text-sm sm:grid-cols-3 dark:border-slate-800">
              <div class="py-5 sm:pr-6">
                <span class="block font-display text-2xl text-text dark:text-white">AI</span>
                <span class="mt-1 block text-text-secondary dark:text-slate-400">RAG, agents, evaluation</span>
              </div>
              <div class="border-t border-border py-5 sm:border-t-0 sm:border-l sm:px-6 dark:border-slate-800">
                <span class="block font-display text-2xl text-text dark:text-white">DX</span>
                <span class="mt-1 block text-text-secondary dark:text-slate-400">Automation, docs, tooling</span>
              </div>
              <div class="border-t border-border py-5 sm:border-t-0 sm:border-l sm:pl-6 dark:border-slate-800">
                <span class="block font-display text-2xl text-text dark:text-white">MVP</span>
                <span class="mt-1 block text-text-secondary dark:text-slate-400">Microsoft AI community</span>
              </div>
            </div>
          </div>

          <aside class="min-w-0 border border-border bg-white/74 p-5 shadow-[0_24px_80px_rgba(34,38,42,0.08)] backdrop-blur dark:border-slate-800 dark:bg-slate-900/60">
            <div class="flex items-start gap-4">
              <img
                src="/images/authors/minseok.jpg"
                alt="Minseok Song"
                class="h-16 w-16 object-cover grayscale"
                loading="eager"
              />
              <div>
                <p class="font-display text-lg font-medium text-text dark:text-white">
                  Minseok Song
                </p>
                <p class="mt-1 text-sm leading-6 text-text-secondary dark:text-slate-400">
                  Microsoft AI MVP · AI Engineer writing about the work behind reliable AI systems.
                </p>
              </div>
            </div>
            <div class="mt-8 border-t border-border pt-5 dark:border-slate-800">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Current focus</p>
              <ul class="mt-4 space-y-3 text-sm leading-6 text-text-secondary dark:text-slate-300">
                <li>Document-grounded AI architecture and evaluation.</li>
                <li>Localization automation for developer-facing content.</li>
                <li>Engineering workflows that make teams faster without hiding quality.</li>
              </ul>
            </div>
            <div class="mt-8 grid grid-cols-3 border-t border-border pt-5 text-center dark:border-slate-800">
              <div>
                <span class="block font-display text-xl text-text dark:text-white">01</span>
                <span class="mt-1 block text-[0.68rem] uppercase tracking-[0.14em] text-text-secondary">Essays</span>
              </div>
              <div class="border-l border-border dark:border-slate-800">
                <span class="block font-display text-xl text-text dark:text-white">02</span>
                <span class="mt-1 block text-[0.68rem] uppercase tracking-[0.14em] text-text-secondary">Systems</span>
              </div>
              <div class="border-l border-border dark:border-slate-800">
                <span class="block font-display text-xl text-text dark:text-white">03</span>
                <span class="mt-1 block text-[0.68rem] uppercase tracking-[0.14em] text-text-secondary">Notes</span>
              </div>
            </div>
          </aside>
        </div>
      ) : (
        <div
          class:list={[
            'max-w-4xl',
            isArticle ? 'mx-auto' : '',
          ]}
        >
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand">
            {category ?? subtitle}
          </p>
          <h1
            class:list={[
              'mt-5 font-display font-medium leading-tight tracking-tight text-text dark:text-white',
              isArticle ? 'max-w-3xl text-3xl sm:text-4xl lg:text-5xl' : 'text-4xl sm:text-5xl',
            ]}
          >
            {isListing ? 'Writing on practical AI systems and developer tools' : title}
          </h1>
          {intro && (
            <p class="mt-6 max-w-3xl text-lg leading-8 text-text-secondary dark:text-slate-300">
              {intro}
            </p>
          )}

          {isArticle && takeaways.length > 0 && (
            <aside class="mt-7 grid gap-5 border border-border bg-bg/78 p-5 shadow-[0_18px_60px_rgba(34,38,42,0.06)] backdrop-blur sm:grid-cols-[11rem_minmax(0,1fr)] dark:border-slate-800 dark:bg-slate-900/58">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">
                  In this article
                </p>
                <p class="mt-3 text-sm leading-6 text-text-secondary dark:text-slate-400">
                  A quick map of the decisions this note is trying to clarify.
                </p>
              </div>
              <ul class="space-y-3 text-sm leading-6 text-text dark:text-slate-100">
                {takeaways.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-[0.65rem] h-1.5 w-1.5 shrink-0 bg-brand" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </aside>
          )}

          {(authorProfile || displayMeta || tags.length > 0) && (
            <div class="mt-7 flex flex-col gap-5 border-t border-border pt-6 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800">
              {authorProfile && (
                <a
                  href={authorProfile.linkedinUrl ?? '#'}
                  target={authorProfile.linkedinUrl ? '_blank' : undefined}
                  rel={authorProfile.linkedinUrl ? 'noopener noreferrer' : undefined}
                  class="flex items-center gap-3"
                >
                  {authorProfile.avatarUrl && (
                    <img
                      src={authorProfile.avatarUrl}
                      alt={authorProfile.name}
                      class="h-11 w-11 object-cover grayscale"
                      loading="lazy"
                    />
                  )}
                  <span class="flex flex-col">
                    <span class="font-medium text-text dark:text-white">{authorProfile.name}</span>
                    {authorProfile.title && (
                      <span class="text-sm text-text-secondary dark:text-slate-400">
                        {authorProfile.title}
                      </span>
                    )}
                  </span>
                </a>
              )}
              <div class="space-y-3 text-sm text-text-secondary sm:text-right dark:text-slate-400">
                {displayMeta && <p>{displayMeta}</p>}
                {tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 sm:justify-end">
                    {tags.map((tag) => (
                      <span class="border border-border px-2.5 py-1 text-xs dark:border-slate-800">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <main class="relative z-10 mx-auto w-full max-w-8xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    {showArchive ? (
      <div class="grid gap-12 lg:grid-cols-[14rem_minmax(0,1fr)]">
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Archive</p>
            <nav aria-label="Writing archive" class="mt-5 space-y-8 text-sm">
              {sidebarNavigation.map((section) => (
                <section>
                  <h2 class="font-display text-base font-medium text-text dark:text-white">
                    {section.title}
                  </h2>
                  <ul class="mt-3 space-y-3 border-l border-border pl-4 dark:border-slate-800">
                    {section.links.map((link) => {
                      const isActive = link.href === currentPath
                      return (
                        <li>
                          <a
                            href={link.href}
                            class={
                              isActive
                                ? 'text-brand'
                                : 'text-text-secondary transition-colors hover:text-text dark:text-slate-400 dark:hover:text-white'
                            }
                          >
                            {link.title}
                          </a>
                        </li>
                      )
                    })}
                  </ul>
                </section>
              ))}
            </nav>
          </div>
        </aside>
        <div class="min-w-0">
          <slot />
        </div>
      </div>
    ) : proseContent ? (
      <div class="grid gap-12 xl:grid-cols-[minmax(0,46rem)_16rem] xl:justify-center">
        <article class="min-w-0">
          <div class="prose editorial-prose max-w-none dark:prose-invert">
            <slot />
          </div>
        </article>

        {showToc && (
          <aside class="hidden xl:block">
            <nav aria-labelledby="on-this-page-title" class="sticky top-24 border-l border-border pl-5 text-sm dark:border-slate-800">
              <h2 id="on-this-page-title" class="font-display text-base font-medium text-text dark:text-white">
                On this page
              </h2>
              <ol role="list" class="mt-4 space-y-3">
                {toc.map((section) => (
                  <li>
                    <a
                      href={`#${section.id}`}
                      class="text-text-secondary transition-colors hover:text-brand dark:text-slate-400"
                    >
                      {section.title}
                    </a>
                    {section.children && section.children.length > 0 && (
                      <ol role="list" class="mt-2 space-y-2 pl-4">
                        {section.children.map((sub) => (
                          <li>
                            <a
                              href={`#${sub.id}`}
                              class="text-text-secondary transition-colors hover:text-brand dark:text-slate-500"
                            >
                              {sub.title}
                            </a>
                          </li>
                        ))}
                      </ol>
                    )}
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )}
      </div>
    ) : (
      <div class="mx-auto max-w-5xl">
        <slot />
      </div>
    )}
  </main>
</div>
