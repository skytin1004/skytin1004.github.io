---
import '../../../styles/tailwind.css'
import EditorialPostList from '../../../components/EditorialPostList'
import BlogLayout from '../../../layouts/BlogLayout.astro'
import GA4 from '../../../components/GA4.astro'
import SeoHead from '../../../components/SeoHead.astro'
import { getAuthor } from '../../../lib/authors'
import { getBlogNavigation } from '../../../lib/blogNavigation'
import { getPublishedBlogPosts } from '../../../lib/blogPosts'
import { site } from '../../../lib/site'
import { blogDefaultLocale } from '../../../locales/config'

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts(blogDefaultLocale)
  const years = Array.from(
    new Set(
      posts
        .map((post) => post.data.date?.getFullYear())
        .filter((year): year is number => typeof year === 'number'),
    ),
  )

  return years.map((year) => ({
    params: { year: String(year) },
  }))
}

const locale = blogDefaultLocale
const year = Number(Astro.params.year)
const posts = await getPublishedBlogPosts(locale, { year })
const blogNavigation = await getBlogNavigation(locale)
const archiveDescription = `Technical writing, talks, and field notes published in ${year}.`

const postCards = posts.map((post) => {
  const authorProfile = getAuthor(post.data.author)

  return {
    href: `/blog/${post.id}`,
    title: post.data.title,
    description: post.data.description,
    category: post.data.category,
    date:
      post.data.date?.toLocaleDateString?.('en', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }) ?? undefined,
    readingTimeMinutes: post.data.readingTimeMinutes,
    tags: post.data.tags,
    authorName: authorProfile?.name,
    authorTitle: authorProfile?.title,
  }
})
---

<html lang={locale} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={`${year} Writing`}
      description={archiveDescription}
      path={`/blog/archive/${year}`}
      type="collection"
      locale={locale}
    />
    <GA4 />
  </head>
  <body class="bg-bg">
    <BlogLayout
      title={`${year} Writing`}
      intro={archiveDescription}
      currentPath={`/blog/archive/${year}`}
      navigation={blogNavigation}
      variant="listing"
    >
      <EditorialPostList
        posts={postCards}
        heading={`${year} writing`}
        intro={`A filtered archive of notes, public articles, and talks from ${year}.`}
      />
    </BlogLayout>
  </body>
</html>
