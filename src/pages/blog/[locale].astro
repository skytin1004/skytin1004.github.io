---
import '../../styles/tailwind.css'
import EditorialPostList from '../../components/EditorialPostList'
import BlogLayout from '../../layouts/BlogLayout.astro'
import SeoHead from '../../components/SeoHead.astro'
import { getBlogNavigation } from '../../lib/blogNavigation'
import { getPublishedBlogPosts } from '../../lib/blogPosts'
import { site } from '../../lib/site'
import { blogLocales, blogDefaultLocale, isSupportedBlogLocale } from '../../locales/config'
import GA4 from '../../components/GA4.astro'
import { getAuthor } from '../../lib/authors'

export async function getStaticPaths() {
  return blogLocales.filter((l) => !l.isDefault).map((lang) => ({
    params: { locale: lang.code },
  }))
}

const { locale: rawLocale } = Astro.params
const locale = isSupportedBlogLocale(rawLocale) ? rawLocale : blogDefaultLocale

const posts = await getPublishedBlogPosts(locale)
const blogNavigation = await getBlogNavigation(locale)

const postCards = posts.map((post) => {
  const authorProfile = getAuthor(post.data.author)

  return {
    href: `/blog/${post.id}`,
    title: post.data.title,
    description: post.data.description,
    category: post.data.category,
    date:
      post.data.date?.toLocaleDateString?.('en', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }) ?? undefined,
    readingTimeMinutes: post.data.readingTimeMinutes,
    tags: post.data.tags,
    authorName: authorProfile?.name,
    authorTitle: authorProfile?.title,
  }
})
---
<html lang={locale} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title="Writing"
      description={site.description}
      path={`/blog/${locale}`}
      type="collection"
      locale={locale}
    />
    <GA4 />
  </head>
  <body class="bg-bg">
    <BlogLayout
      title={site.title}
      intro={site.description}
      currentPath={`/blog/${locale}`}
      navigation={blogNavigation}
      variant="listing"
    >
      <EditorialPostList posts={postCards} />
    </BlogLayout>
  </body>
</html>
