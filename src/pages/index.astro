---
import '../styles/tailwind.css'
import EditorialPostList from '../components/EditorialPostList'
import BlogLayout from '../layouts/BlogLayout.astro'
import GA4 from '../components/GA4.astro'
import { getAuthor } from '../lib/authors'
import { getBlogNavigation } from '../lib/blogNavigation'
import { getPublishedBlogPosts } from '../lib/blogPosts'
import { site } from '../lib/site'
import { blogDefaultLocale } from '../locales/config'

const locale = blogDefaultLocale
const posts = await getPublishedBlogPosts(locale)
const blogNavigation = await getBlogNavigation(locale)
const ogImageUrl = new URL(site.ogImage, Astro.site).toString()

const postCards = posts.map((post) => {
  const authorProfile = getAuthor(post.data.author)

  return {
    href: `/blog/${post.id}`,
    title: post.data.title,
    description: post.data.description,
    category: post.data.category,
    date:
      post.data.date?.toLocaleDateString?.('en', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }) ?? undefined,
    readingTimeMinutes: post.data.readingTimeMinutes,
    tags: post.data.tags,
    authorName: authorProfile?.name,
    authorTitle: authorProfile?.title,
  }
})
---

<html lang={locale} class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.title}</title>
    <meta name="description" content={site.description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <GA4 />
  </head>
  <body class="bg-bg">
    <BlogLayout
      title={site.title}
      intro={site.description}
      currentPath="/"
      navigation={blogNavigation}
      variant="home"
    >
      <EditorialPostList posts={postCards} />
    </BlogLayout>
  </body>
</html>
